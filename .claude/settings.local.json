{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(mvn -q -DskipTests compile)",
      "Bash(mvn -q test)",
      "Bash(mvn -q verify)",
      "Bash(mvn -q -DskipTests package)",
      "Bash(mvn -q spotless:apply)",
      "Bash(mvn -q checkstyle:check)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(grep:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 7* *)",
      "Read(./.env)",
      "Read(./secrets/**)",
      "Read(./**/application-prod.yml)",
      "Read(./**/application-prod.properties)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "ask": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git rebase *)"
    ]
  }
}
